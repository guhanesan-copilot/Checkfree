{
  "_version": "1.65.0",

  "sap.app": {
    "id":          "com.sap.payments.paymentruns",
    "type":        "application",
    "title":       "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri":  "/payment/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "i18n": "i18n/i18n.properties"
  },

  "sap.ui": {
    "technology":      "UI5",
    "icons":           { "icon": "sap-icon://download" },
    "deviceTypes":     { "desktop": true, "tablet": true, "phone": false },
    "fullWidth":       false,
    "supportedThemes": ["sap_horizon", "sap_horizon_dark", "sap_fiori_3"]
  },

  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m":            {},
        "sap.ui.core":      {},
        "sap.uxap":         {},
        "sap.fe.templates": {},
        "sap.fe.core":      {}
      }
    },

    "contentDensities": { "compact": true, "cozy": true },

    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName":       "com.sap.payments.paymentruns.i18n.i18n",
          "supportedLocales": [""],
          "fallbackLocale":   ""
        }
      },
      "": {
        "dataSource": "mainService",
        "preload":    true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode":       "Server",
          "autoExpandSelect":    true,
          "earlyRequests":       true
        }
      }
    },

    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name":    "PaymentRunsList",
          "target":  "PaymentRunsList"
        },
        {
          "pattern": "PaymentRuns({key}):?query:",
          "name":    "PaymentRunsObjectPage",
          "target":  "PaymentRunsObjectPage"
        },
        {
          "pattern": "PaymentRuns({key})/Payments({key2}):?query:",
          "name":    "PaymentDetailsObjectPage",
          "target":  "PaymentDetailsObjectPage"
        }
      ],
      "targets": {
        "PaymentRunsList": {
          "type": "Component",
          "id":   "PaymentRunsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet":         "PaymentRuns",
              "variantManagement": "None",
              "initialLoad":       "Enabled",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type":         "ResponsiveTable",
                    "selectionMode": "None",
                    "enableExport":  true
                  }
                }
              }
            }
          }
        },

        "PaymentRunsObjectPage": {
          "type": "Component",
          "id":   "PaymentRunsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet":             "PaymentRuns",
              "editableHeaderContent": false,
              "controlConfiguration": {
                "Payments/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type":          "ResponsiveTable",
                    "enableExport":  true,
                    "selectionMode": "None"
                  }
                }
              },
              "content": {
                "body": {
                  "sections": {
                    "PaymentDetailsSection": {
                      "actions": {
                        "DownloadCSV": {
                          "handlers": {
                            "press": "com.sap.payments.paymentruns.ext.controller.ListReportExt#onDownloadCSV"
                          },
                          "text":    "Download CSV",
                          "enabled": true
                        },
                        "DownloadXLSX": {
                          "handlers": {
                            "press": "com.sap.payments.paymentruns.ext.controller.ListReportExt#onDownloadXLSX"
                          },
                          "text":    "Download XLSX",
                          "enabled": true
                        },
                        "DownloadWithCards": {
                          "handlers": {
                            "press": "com.sap.payments.paymentruns.ext.controller.ListReportExt#onDownloadWithCards"
                          },
                          "text":    "Download with Cards",
                          "enabled": true
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },

        "PaymentDetailsObjectPage": {
          "type": "Component",
          "id":   "PaymentDetailsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet":             "PaymentDetails",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  }
}
